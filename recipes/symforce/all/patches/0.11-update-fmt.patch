diff --git a/symforce/opt/fmt_compat.h b/symforce/opt/fmt_compat.h
new file mode 100644
--- /dev/null
+++ b/symforce/opt/fmt_compat.h
@@ -0,0 +1,38 @@
+/*
+ * fmt >= 11 no longer auto-discovers operator<< for formatting.
+ * This header restores it: any class with operator<< is formatted via
+ * fmt::ostream_formatter, and Eigen matrices keep their operator<< layout
+ * instead of fmt/ranges.h's flat element list.
+ */
+
+#pragma once
+
+#include <ostream>
+#include <type_traits>
+#include <utility>
+
+#include <fmt/ostream.h>
+#include <fmt/ranges.h>
+
+namespace sym::fmt_compat {
+template <typename T, typename = void>
+struct is_ostreamable : std::false_type {};
+template <typename T>
+struct is_ostreamable<
+    T, std::void_t<decltype(std::declval<std::ostream&>() << std::declval<const T&>())>>
+    : std::true_type {};
+}  // namespace sym::fmt_compat
+
+// Eigen 3.4+ exposes begin()/end(); disable fmt's range formatter for Eigen
+// expressions (detected via .derived()) so operator<< is used instead.
+template <typename T>
+struct fmt::range_format_kind<T, char, std::void_t<decltype(std::declval<const T&>().derived())>>
+    : std::integral_constant<fmt::range_format, fmt::range_format::disabled> {};
+
+// Catch-all ostream formatter for class types with operator<<, excluding
+// strings (formatted natively by fmt).
+template <typename T>
+struct fmt::formatter<
+    T, char,
+    std::enable_if_t<std::is_class_v<T> && !std::is_convertible_v<const T&, fmt::string_view> &&
+                     sym::fmt_compat::is_ostreamable<T>::value>> : fmt::ostream_formatter {};
